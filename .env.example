# Cloudflare AI Gateway Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# CLOUDFLARE ACCOUNT
# =============================================================================

# Your Cloudflare Account ID (found in dashboard or via API)
CF_ACCOUNT_ID=your_account_id_here

# =============================================================================
# AI GATEWAY
# =============================================================================

# Your AI Gateway ID (e.g., "default" or a custom gateway name)
CF_GATEWAY_ID=default

# AI Gateway Runtime Token (starts with cfut_)
# Used for: Making requests through the AI Gateway proxy
# DO NOT use this for Cloudflare REST API calls
AIG_TOKEN=cfut_your_runtime_token_here

# AI Gateway Management Token (starts with cfat_)
# Used for: Cloudflare REST API calls (gateways, logs, analytics)
# DO NOT use this for AI Gateway proxy requests
CFAT_TOKEN=cfat_your_management_token_here

# =============================================================================
# CUSTOM PROVIDER (MiniMax)
# =============================================================================

# Provider slug as configured in AI Gateway dashboard
# This appears in the URL path as /custom-{PROVIDER_SLUG}/
PROVIDER_SLUG=minimax

# MiniMax API Key (stored as Provider Key via BYOK in AI Gateway dashboard)
# This is NOT passed in requests — it's stored in Cloudflare and injected at runtime
MINIMAX_API_KEY=your_minimax_api_key_here

# The base_url configured for the custom provider
# IMPORTANT: Must include /anthropic path for MiniMax
PROVIDER_BASE_URL=https://api.minimax.io

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Default chat model
CHAT_MODEL=MiniMax-M2.7

# TTS model (ensure this is available on your plan)
TTS_MODEL=speech-2.8-hd

# TTS voice ID (male-qn-qingse or female-tianmei)
TTS_VOICE=male-qn-qingse

# =============================================================================
# CACHING
# =============================================================================

# Default cache TTL in seconds (60 min to 1 month)
# Set to 0 to disable caching by default
DEFAULT_CACHE_TTL=300

# Broadcast cache TTL (for IPL scores, news, etc.)
BROADCAST_CACHE_TTL=3600

# =============================================================================
# RATE LIMITING
# =============================================================================

# Max requests per minute per key (0 = unlimited)
RATE_LIMIT_RPM=60

# =============================================================================
# ENDPOINTS
# =============================================================================

# AI Gateway base URL
AIG_BASE_URL=https://gateway.ai.cloudflare.com/v1/${CF_ACCOUNT_ID}/${CF_GATEWAY_ID}

# Provider-native endpoint
AIG_PROVIDER_URL=${AIG_BASE_URL}/custom-${PROVIDER_SLUG}

# Unified API endpoint
AIG_COMPAT_URL=${AIG_BASE_URL}/compat
